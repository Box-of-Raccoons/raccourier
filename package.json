{
  "name": "raccourier",
  "version": "1.0.0",
  "description": "Desktop notifier that Claude can push mail-triage summaries and alerts to.",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "mcp": "node mcp/server.js",
    "test": "vitest run",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "dompurify": "^3.1.7",
    "marked": "^14.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "vitest": "^2.1.4"
  },
  "build": {
    "appId": "com.raccourier.app",
    "productName": "Raccourier",
    "files": ["app/**/*", "mcp/**/*", "shared/**/*", "build/icon.png", "package.json"],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Raccourier"
    }
  }
}
